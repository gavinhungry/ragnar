#!/bin/bash
#
# Name: ragnar
# Auth: Gavin Lloyd <gavinhungry@gmail.com>
# Desc: Mount an existing remote LUKS device with NBD over SSH
#
# Released under the terms of the MIT license
# https://github.com/gavinhungry/ragnar
#

[ ${_ABASH:-0} -ne 0 ] || source $(dirname "${BASH_SOURCE}")/abash/abash.sh

SSH_SERVER=${RAGNAR_SSH_SERVER:-${RAGNAR_SERVER:-localhost}}
NBD_EXPORT=${RAGNAR_NBD_EXPORT:-${RAGNAR_NBDEXPORT:-ragnar}}
NBD_LOCAL_PORT=${RAGNAR_NBD_LOCAL_PORT:-${RAGNAR_PORT:-10809}}
LUKS_HEADER=${RAGNAR_LUKS_HEADER:-${RAGNAR_HEADER:-/etc/luks/${NBD_EXPORT}.header}}
LUKS_KEYFILE=${RAGNAR_LUKS_KEYFILE:-${RAGNAR_KEYFILE:-/etc/luks/${NBD_EXPORT}.key}}
MOUNTPOINT=${RAGNAR_MOUNTPOINT:-}
MOUNT_OPTIONS=${RAGNAR_MOUNT_OPTIONS:-}

SSH="${SUDO_USER:+checksu -u "$SUDO_USER"} /usr/bin/ssh"

TMP="${TMPDIR:-/tmp}/ragnar-${SSH_SERVER}-${NBD_EXPORT}"
mkdir -m 0700 -p "$TMP"
[ -n "$SUDO_USER" ] && chown "$SUDO_USER":"$SUDO_USER" "$TMP"

clean_tmp() {
  rm -fr "$TMP"
}

ssh_is_open() {
  $SSH -qO check -S "${TMP}/ssh" ${SSH_SERVER} &> /dev/null
}

open_ssh() {
  $SSH -fNn -MS "${TMP}/ssh" -L ${NBD_LOCAL_PORT}:127.0.0.1:10809 ${SSH_SERVER}
}

close_ssh() {
  if ssh_is_open; then
    $SSH -qO exit -S "${TMP}/ssh" ${SSH_SERVER}
  fi
}

nbd_device() {
  cat "${TMP}/nbd" 2> /dev/null
}

nbd_is_open() {
  [ -f "/sys/block/${1}/pid" ]
}

nbd_next_open() {
  checksu modprobe nbd

  for DEV in /dev/nbd*; do
    NBD=$(echo ${DEV} | cut -d'/' -f3)
    if ! nbd_is_open ${NBD}; then
      echo ${NBD}
      return
    fi
  done
}

export_is_open() {
  [ -f "${TMP}/nbd" ] || return 1
  nbd_is_open $(nbd_device)
}

open_export() {
  checksu modprobe nbd
  NBD=$1

  if quietly checksu nbd-client 127.0.0.1 ${NBD_LOCAL_PORT} /dev/${NBD} -name ${NBD_EXPORT}; then
    echo ${NBD} > ${TMP}/nbd
  else
    close_ssh
    clean_tmp
    return 1
  fi
}

close_export() {
  if export_is_open; then
    checksu
    checksu modprobe nbd
    quietly checksu nbd-client -d /dev/$(nbd_device) && quietly rm -f "${TMP}/nbd"
  fi
}

luks_is_open() {
  [ -b /dev/mapper/${NBD_EXPORT} ]
}

luks_open() {
  NBD=$1
  checksu [ -f "${LUKS_HEADER}" ] || LUKS_HEADER="${NBD}"
  checksu cryptsetup luksOpen /dev/${NBD} ${NBD_EXPORT} -d "${LUKS_KEYFILE}" --header "${LUKS_HEADER}"
}

luks_close() {
  checksu cryptsetup luksClose /dev/mapper/${NBD_EXPORT}
}

filesystem_mountpoint() {
  udisksctl info -b /dev/mapper/${NBD_EXPORT} 2> /dev/null | grep MountPoints | cut -d':' -f2 | sed 's/^\s*//'
}

filesystem_is_mounted() {
  [ -n "$(filesystem_mountpoint)" ]
}

mount_filesystem() {
  local -a COMMAND

  if [ -n "${MOUNTPOINT}" ]; then
    COMMAND=(mount)
  else
    COMMAND=(udisksctl mount -b /dev/mapper/${NBD_EXPORT})
  fi

  [ -z "${MOUNT_OPTIONS}" ] || COMMAND+=(-o "${MOUNT_OPTIONS}")
  [ -z "${MOUNTPOINT}" ] || COMMAND+=(/dev/mapper/${NBD_EXPORT} "${MOUNTPOINT}")

  quietly checksu "${COMMAND[@]}"
}

unmount_filesystem() {
  if [ -n "${MOUNTPOINT}" ]; then
    quietly checksu umount "${MOUNTPOINT}"
  else
    quietly checksu udisksctl unmount -b /dev/mapper/${NBD_EXPORT}
  fi
}

open_transport() {
  export_is_open && die "${NBD_EXPORT} already open on $(nbd_device)"

  inform "Opening SSH connection to ${SSH_SERVER}"
  open_ssh || die "Could not open SSH connection to ${SSH_SERVER}"
  sleep 1

  NBD=$(nbd_next_open)
  inform "Opening NBD on /dev/${NBD}"
  open_export ${NBD} || die "Could not open NBD on /dev/${NBD}"
}

close_transport() {
  FAILED=0
  NBD=$(nbd_device)

  if export_is_open; then
    inform "Closing NBD on /dev/${NBD}"
    close_export || FAILED=1
  fi

  if ssh_is_open; then
    inform "Closing SSH connection to ${SSH_SERVER}"
    close_ssh || FAILED=1
  fi

  [ ${FAILED} -eq 0 ] || return 1
  clean_tmp
}

attach() {
  open_transport >&2 || return 1
  echo "/dev/${NBD}"
}

detach() {
  close_transport >&2
}

open() {
  export_is_open && die "${NBD_EXPORT} already open on $(nbd_device)"
  checksu [ -f "${LUKS_KEYFILE}" ] || die "Keyfile not found"
  [ -z "${MOUNTPOINT}" ] || [ -d "${MOUNTPOINT}" ] || die "Mountpoint does not exist: ${MOUNTPOINT}"

  open_transport

  inform "Opening LUKS device from /dev/${NBD}"
  luks_open ${NBD} || die "Could not open LUKS device from /dev/${NBD}"

  inform "Mounting filesystem from /dev/mapper/${NBD_EXPORT}"
  mount_filesystem || die "Could not mount filesystem from /dev/mapper/${NBD_EXPORT}"

  msg "Filesystem is mounted on $(filesystem_mountpoint)"
}

close() {
  export_is_open || die "${NBD_EXPORT} is not open"
  NBD=$(nbd_device)

  checksu

  MOUNTPOINT=$(filesystem_mountpoint)

  filesystem_is_mounted && inform "Closing filesystem on ${MOUNTPOINT}"
  unmount_filesystem || die "Could not close filesystem on ${MOUNTPOINT}"

  luks_is_open && inform "Closing LUKS device from /dev/${NBD}"
  luks_close || die "Could not close LUKS device from /dev/${NBD}"

  close_transport
}

case $1 in
  'open') open ;;
  'close') close ;;
  'attach') attach ;;
  'detach') detach ;;
  *) usage '[open|close|attach|detach]' ;;
esac
